#!/usr/bin/env python3
# arxos-welcome - post-login welcome splash for ArxOS.
# JARVIS-toned greeting + live time + a rotating motivation/productivity fact, in the
# ArxOS greeter/site design (Inter + Playfair Display, gold accent, animated 3D plexus,
# flat segmented loader). NO network on the login path (performance first): 20 facts ship
# built-in and show instantly. A detached background job adds ~5 fresh facts once a day,
# only when the network is up - it never blocks login.
import os, sys, html, datetime, tempfile, subprocess, json, random
os.environ.setdefault("WEBKIT_DISABLE_COMPOSITING_MODE", "1")
os.environ.setdefault("GDK_BACKEND", "x11")

