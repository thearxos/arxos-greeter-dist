def _cache_dir():
    d = os.path.join(os.environ.get("XDG_CACHE_HOME", os.path.expanduser("~/.cache")), "arxos")
    os.makedirs(d, exist_ok=True); return d

def load_facts():
    pool = list(FACTS)
    try:
        pool += json.load(open(os.path.join(_cache_dir(), "facts.json")))
    except Exception:
        pass
    return pool or list(FACTS)

def refresh_facts():
    # runs detached, after login, ONLY when online, at most once a day; best-effort.
    stamp = os.path.join(_cache_dir(), "facts.stamp")
    today = datetime.date.today().isoformat()
    try:
        if os.path.exists(stamp) and open(stamp).read().strip() == today:
            return
    except Exception:
        pass
    try:
        import urllib.request
        req = urllib.request.Request("https://zenquotes.io/api/quotes",
                                     headers={"User-Agent": "curl/8"})
        data = json.load(urllib.request.urlopen(req, timeout=6))
        picks = random.sample(data, min(5, len(data)))
        new = [("%s  -  %s" % (q.get("q", "").strip(), q.get("a", "").strip())).strip()
               for q in picks if q.get("q")]
    except Exception:
        return   # no network / API down: keep the built-ins, try again tomorrow
    cf = os.path.join(_cache_dir(), "facts.json")
    try: pool = json.load(open(cf))
    except Exception: pool = []
    for f in new:
        if f and f not in pool: pool.append(f)
    pool = pool[-120:]
    try:
        json.dump(pool, open(cf, "w")); open(stamp, "w").write(today)
    except Exception:
        pass

def greeting():
    h = datetime.datetime.now().hour
    if   5 <= h < 12: return "Good morning"
    elif 12 <= h < 17: return "Good afternoon"
    elif 17 <= h < 22: return "Good evening"
    else:              return "Working late"

