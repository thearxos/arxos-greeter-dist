def sysinfo():
    # local, non-network system facts for the info line
    bits = ["ArxOS %s" % VERSION]
    try: bits.append("kernel " + os.uname().release.split("-")[0])
    except Exception: pass
    try:
        c = os.cpu_count()
        if c: bits.append("%d cores" % c)
    except Exception: pass
    try:
        kb = int(next(l.split()[1] for l in open("/proc/meminfo") if l.startswith("MemTotal")))
        bits.append("%d GB RAM" % round(kb / 1048576))
    except Exception: pass
    return "  ·  ".join(bits)

def build():
    return PAGE % {"greet": html.escape(greeting()),
                   "fact": html.escape(random.choice(load_facts())),
                   "info": html.escape(sysinfo())}

def show_splash():
    import gi
    gi.require_version("Gtk", "3.0")
    try: gi.require_version("WebKit2", "4.1")
    except Exception: gi.require_version("WebKit2", "4.0")
    from gi.repository import Gtk, WebKit2, GLib, Gdk

    class Splash(Gtk.Window):
        def __init__(self):
            super().__init__(type=Gtk.WindowType.TOPLEVEL)
            self.set_decorated(False); self.set_skip_taskbar_hint(True)
            self.set_skip_pager_hint(True); self.set_keep_above(True); self.fullscreen()
            # black from the very first frame, so no wallpaper ever shows through
            # (the window + the webview are both black before the page paints)
            self.set_app_paintable(True)
            try:
                _css = Gtk.CssProvider(); _css.load_from_data(b"window, scrolledwindow, webkitwebview { background:#000; }")
                Gtk.StyleContext.add_provider_for_screen(Gdk.Screen.get_default(), _css,
                                                         Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION)
            except Exception:
                pass
            self._tmp = tempfile.NamedTemporaryFile("w", suffix=".html", delete=False)
            self._tmp.write(build()); self._tmp.close()
            wv = WebKit2.WebView()
            try: wv.set_background_color(Gdk.RGBA(0, 0, 0, 1))
            except Exception: pass
            wv.load_uri("file://" + self._tmp.name)
            self.add(wv)
            self.connect("destroy", self._quit)
            GLib.timeout_add(5600, self._quit)
        def _quit(self, *a):
            try: os.unlink(self._tmp.name)
            except Exception: pass
            Gtk.main_quit(); return False

    w = Splash(); w.show_all(); w.present(); Gtk.main()

if __name__ == "__main__":
    if "--version" in sys.argv or "-V" in sys.argv:
        print("arxos-welcome %s (ArxOS)" % VERSION); sys.exit(0)
    if "--refresh-facts" in sys.argv:
        refresh_facts(); sys.exit(0)
    # kick off the daily fact refresh in the background (detached; never blocks the splash)
    try:
        subprocess.Popen(["setsid", sys.executable, os.path.realpath(__file__), "--refresh-facts"],
                         stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, stdin=subprocess.DEVNULL)
    except Exception:
        pass
    show_splash()
